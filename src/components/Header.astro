---
const today = new Date();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-gray-50 border-t border-gray-100 py-16 mt-24">
	<div class="max-w-[800px] mx-auto px-6 text-center">
		<p class="text-gray-500 text-[0.8rem] mb-8">
			&copy; {today.getFullYear()} Clienvora. All rights reserved.
		</p>
		
		<nav class="flex justify-center flex-wrap gap-x-8 gap-y-4">
			<a href={base} class="text-gray-700 hover:text-black text-[0.85rem] font-medium uppercase tracking-widest transition">Home</a>
			<a href={base + 'blog'} class="text-gray-700 hover:text-black text-[0.85rem] font-medium uppercase tracking-widest transition">Blog</a>
			<a href={base + 'about'} class="text-gray-700 hover:text-black text-[0.85rem] font-medium uppercase tracking-widest transition">About</a>
			<a href="https://www.clienvora.com" target="_blank" rel="noopener" class="text-gray-700 hover:text-black text-[0.85rem] font-medium uppercase tracking-widest transition">Website</a>
			<a href="https://wa.me/923204779972" target="_blank" rel="noopener" class="text-gray-700 hover:text-black text-[0.85rem] font-medium uppercase tracking-widest transition">WhatsApp</a>
			<a href="https://github.com/amirali115c-hub" target="_blank" rel="noopener" class="text-gray-700 hover:text-black text-[0.85rem] font-medium uppercase tracking-widest transition">GitHub</a>
		</nav>
	</div>
</footer>
