---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="brand"><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/amirali115c-hub" target="_blank" rel="noopener noreferrer">GitHub</a>
			<a href="https://wa.me/923204779972" target="_blank" rel="noopener noreferrer">WhatsApp</a>
			<a href="https://www.clienvora.com" target="_blank" rel="noopener noreferrer">Website</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2rem;
		background: #fff;
		border-bottom: 1px solid #f0f0f0;
	}
	.brand { font-size: 1.25rem; font-weight: 700; margin: 0; }
	.brand a { text-decoration: none; color: #000; }
	
	nav { display: flex; align-items: center; justify-content: space-between; height: 80px; }
	
	.internal-links a { margin-right: 1.5rem; text-decoration: none; color: #666; font-size: 0.9rem; }
	.internal-links a:hover { color: #000; }
	
	.social-links { display: flex; gap: 1.5rem; }
	.social-links a { text-decoration: none; color: #000; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
	.social-links a:hover { opacity: 0.7; }

	@media (max-width: 720px) {
		.social-links { display: none; }
	}
</style>
