---
const today = new Date();
---

<footer>
	<div class="footer-container">
		<p>&copy; {today.getFullYear()} Clienvora. All rights reserved.</p>
		
		<nav class="footer-links">
			<a href="/">Home</a>
			<a href="/blog">Blog</a>
			<a href="/about">About</a>
			<a href="https://www.clienvora.com" target="_blank" rel="noopener">Website</a>
			<a href="https://wa.me/923204779972" target="_blank" rel="noopener">WhatsApp</a>
			<a href="https://github.com/amirali115c-hub" target="_blank" rel="noopener">GitHub</a>
		</nav>
	</div>
</footer>

<style>
	footer {
		padding: 4rem 2rem;
		margin-top: 6rem;
		border-top: 1px solid #f0f0f0;
		text-align: center;
		background: #fff;
	}
	.footer-container { max-width: 800px; margin: 0 auto; }
	
	p { color: #888; font-size: 0.8rem; margin-bottom: 1.5rem; }
	
	.footer-links { 
		display: flex; 
		justify-content: center; 
		flex-wrap: wrap;
		gap: 2rem; 
	}
	
	.footer-links a { 
		color: #333; 
		text-decoration: none; 
		font-size: 0.85rem; 
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: opacity 0.2s;
	}
	
	.footer-links a:hover { opacity: 0.6; }

	@media (max-width: 600px) {
		.footer-links { gap: 1rem; }
	}
</style>
