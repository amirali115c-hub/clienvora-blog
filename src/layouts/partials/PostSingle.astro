---
import Subscribe from "@/components/Subscribe.astro";
import JsonLd from "@/components/JsonLd.astro";
import Post from "@/layouts/components/Post.astro";
import config from "@/config/config.json";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const { post } = Astro.props;
const { Content } = await render(post);
const { title, image, date, description } = post.data;

const posts = await getSinglePage("blog");
const related = sortByDate(posts)
  .filter((p) => p.id !== post.id)
  .slice(0, 3);

const postUrl = `${config.site.base_url}/blog/${post.data.slug ?? post.id}/`;
const published = date ? new Date(date).toISOString() : new Date().toISOString();
const modified = date ? new Date(date).toISOString() : new Date().toISOString();

const siteSameAs = [
  "https://www.clienvora.com",
  "https://wa.me/923204779972",
  "https://github.com/amirali115c-hub",
  "https://www.linkedin.com/",
];

// Build FAQPage schema from the "## FAQ" markdown section
const faqItems = (() => {
  const body = post.body || "";
  const m = body.match(/##\s*FAQ([\s\S]*?)(?=\n##\s|$)/i);
  if (!m) return [];
  const lines = m[1].split("\n");
  const items = [];
  let q = null;
  let a = [];
  const push = () => {
    const answer = a.join(" ").trim().replace(/\*\*/g, "").replace(/\[([^\]]+)\]\([^)]+\)/g, "$1");
    if (q && answer) items.push({ q: q.trim(), a: answer });
  };
  for (const line of lines) {
    const qm = line.match(/^\*\*(.+?)\*\*\s*$/);
    if (qm) {
      push();
      q = qm[1];
      a = [];
    } else if (q !== null) {
      a.push(line);
    }
  }
  push();
  return items;
})();

const faqSchema = faqItems.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqItems.map((i) => ({
        "@type": "Question",
        name: i.q,
        acceptedAnswer: { "@type": "Answer", text: i.a },
      })),
    }
  : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description || "",
  image: image ? `${config.site.base_url}${image}` : `${config.site.base_url}${config.metadata.meta_image}`,
  datePublished: published,
  dateModified: modified,
  author: {
    "@type": "Organization",
    name: config.site.title,
    url: config.site.base_url,
    sameAs: siteSameAs,
  },
  publisher: {
    "@type": "Organization",
    name: config.site.title,
    url: config.site.base_url,
    sameAs: siteSameAs,
    logo: {
      "@type": "ImageObject",
      url: `${config.site.base_url}${config.site.logo}`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: config.site.base_url,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${config.site.base_url}/blog`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: postUrl,
    },
  ],
};
---

<section class="section">
  <div class="container">
    <JsonLd data={articleSchema} />
    <JsonLd data={breadcrumbSchema} />
    {faqSchema && <JsonLd data={faqSchema} />}
    <div class="row justify-center">
      <div class="col-12 md:col-8">
        <article class="text-center">
          {
            image && (
              <Image
                src={image}
                height={500}
                width={1000}
                alt={title}
                class="rounded-lg"
              />
            )
          }
          <h1 set:html={markdownify(title)} class="h2 text-left my-6" />

          <p class="text-sm text-gray-500 mb-6">
            Last updated:{" "}
            {new Date(modified).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </p>

          <div class="content mb-16 text-left">
            <Content />
          </div>

          <div class="border-t border-border pt-8 text-left">
            <Subscribe variant="inline" />
          </div>
        </article>
      </div>
    </div>

    {
      related.length > 0 && (
        <div class="row mt-12">
          <div class="col-12">
            <h2 class="h3 mb-6 text-center">Keep reading</h2>
          </div>
          {related.map((p, i) => (
            <div class="col-12 mb-8 sm:col-6 lg:col-4">
              <Post post={p} index={i} />
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>
